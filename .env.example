# ============================================================
# FER3OON Telegram Sync — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# ── Telegram API credentials ─────────────────────────────────
# Get from https://my.telegram.org/apps
API_ID=YOUR_API_ID_HERE
API_HASH=your_api_hash_here

# ── Session ───────────────────────────────────────────────────
SESSION_NAME=fer3oon_sync_session

# ── Channels ──────────────────────────────────────────────────
# Comma-separated list of source channel usernames (no @)
SOURCE_CHANNELS=ForexBreakingNews

# Destination channel username (no @)
DESTINATION_CHANNEL=FOREX_NEWS_EGY

# ── Hashtag rules ─────────────────────────────────────────────
# Comma-separated hashtags to remove (no #)
REMOVE_HASHTAGS=

# Comma-separated hashtags to add to every post (no #)
ADD_HASHTAGS=

# ── Timing ────────────────────────────────────────────────────
POST_DELAY=1.5
ARCHIVE_BATCH_DELAY=2.0
ARCHIVE_BATCH_SIZE=100

# ── Behavior ──────────────────────────────────────────────────
DUPLICATE_CHECK=true

# ── Database ──────────────────────────────────────────────────
DATABASE_PATH=database/sync.db

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/sync.log

# ── Retry logic ───────────────────────────────────────────────
MAX_RETRIES=5
RETRY_BASE_DELAY=5.0
FLOODWAIT_MULTIPLIER=1.2
